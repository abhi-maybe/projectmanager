# disable next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# app base url
# NEXT_PUBLIC_APP_BASE_URL=https://pm.abhijit.fun
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# optional serverless cloud fallback database (Vercel KV / Upstash Redis)
# if omitted, the application runs entirely locally on local-db.json in the project root.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
